            </form>

            <!-- Participants Section (Step 2, hidden initially) -->
            <div id="participants-section" class="hidden py-8">
              <h3 class="text-2xl font-bold text-dark text-center mb-6">👥 Step 2: 参与者信息</h3>
              
              <form id="participants-form">
                <!-- Pax Selection & Pricing moved to Step 2 -->
                <div class="bg-accent/10 p-6 rounded-xl border border-accent/30 max-w-md mx-auto mb-8">
                  <label class="block text-sm font-semibold text-dark mb-3">👥 报名人数 *</label>
                  <div class="flex items-center gap-4 mb-4">
                    <button type="button" id="pax-minus" class="w-10 h-10 rounded-full bg-primary text-white text-xl font-bold flex items-center justify-center hover:bg-theme-dark transition-all shadow-sm select-none">−</button>
                    <input type="number" id="pax" name="pax" value="1" min="1" max="20" readonly class="w-16 text-center text-2xl font-bold text-dark border-none bg-transparent outline-none" />
                    <button type="button" id="pax-plus" class="w-10 h-10 rounded-full bg-primary text-white text-xl font-bold flex items-center justify-center hover:bg-theme-dark transition-all shadow-sm select-none">+</button>
                  </div>
                  <!-- Pricing Breakdown -->
                  <div id="pricing-breakdown" class="space-y-2 text-base">
                    <div id="row-original" class="flex justify-between items-center hidden">
                      <span class="text-light">原价 (RM 128 × <span id="pax-count">1</span> 人)</span>
                      <span id="price-original" class="font-semibold text-light line-through">RM 128</span>
                    </div>
                    <div class="flex justify-between items-center">
                      <span class="text-light">小计</span>
                      <span id="price-subtotal" class="font-semibold text-dark">RM 128.00</span>
                    </div>
                    <div class="flex justify-between items-center">
                      <span class="text-light">SST (8%)</span>
                      <span id="price-sst" class="font-semibold text-dark">RM 10.24</span>
                    </div>
                    <div class="flex justify-between items-center pt-2 border-t border-accent/30">
                      <span class="font-bold text-dark text-lg">总计</span>
                      <span id="price-total" class="font-bold text-primary text-2xl">RM 138.24</span>
                    </div>
                  </div>
                  <!-- Savings hint (shown for 2+ pax) -->
                  <div id="savings-hint" class="mt-3 text-sm text-primary font-medium hidden">
                    🎉 <span id="savings-text"></span>
                  </div>
                </div>

                <!-- Attendee Details Container -->
                <div id="attendees-container" class="space-y-6 max-w-md mx-auto mb-8">
                  <!-- JS Injects attendee block here -->
                </div>

                <div class="text-center">
                  <button id="participants-next-btn" type="submit" class="w-full max-w-md mx-auto bg-primary hover:bg-theme-dark text-white font-bold text-lg px-8 py-4 rounded-xl transition duration-300 shadow-md flex items-center justify-center gap-2">
                    ➡️ 下一步 (填写发票信息)
                  </button>
                  <button type="button" id="back-to-step1-from-participants" class="mt-4 text-light hover:text-dark underline text-sm">
                    🔙 返回修改报名信息
                  </button>
                </div>
              </form>
            </div>

            <!-- Invoice Details Section (Step 3, hidden initially) -->
            <div id="invoice-section" class="hidden py-8">
              <h3 class="text-2xl font-bold text-dark text-center mb-2">🧾 Step 3: Invoice Details</h3>
              <p class="text-light text-center mb-8 pb-6 border-b border-border-light text-base">发票将在课程结束后发出。 (我们会在24小时内发送进您的邮箱)</p>

              <form id="invoice-form" class="space-y-6">
                <div>
                  <label for="inv_company" class="block text-sm font-semibold text-dark mb-2">公司名称 (Company Name) *</label>
                  <input type="text" id="inv_company" name="inv_company" class="w-full px-4 py-3 rounded-lg border border-border-light focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" required placeholder="发票上的公司名称">
                </div>
                <div>
                  <label for="inv_address" class="block text-sm font-semibold text-dark mb-2">公司地址 (Company Address) *</label>
                  <textarea id="inv_address" name="inv_address" rows="2" class="w-full px-4 py-3 rounded-lg border border-border-light focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all resize-none" required placeholder="发票上的公司地址"></textarea>
                </div>
                <div class="grid md:grid-cols-2 gap-6">
                  <div>
                    <label for="inv_phone" class="block text-sm font-semibold text-dark mb-2">联系电话 (Phone) *</label>
                    <input type="tel" id="inv_phone" name="inv_phone" class="w-full px-4 py-3 rounded-lg border border-border-light focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" required placeholder="发票上的联系电话">
                  </div>
                  <div>
                    <label for="inv_email" class="block text-sm font-semibold text-dark mb-2">邮箱 (Email) *</label>
                    <input type="email" id="inv_email" name="inv_email" class="w-full px-4 py-3 rounded-lg border border-border-light focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" required placeholder="接收发票的邮箱">
                  </div>
                </div>

                <div class="text-center">
                  <button type="submit" id="invoice-next-btn" class="w-full max-w-md mx-auto bg-primary hover:bg-theme-dark text-white font-bold text-lg px-8 py-4 rounded-xl transition duration-300 shadow-md">
                    ➡️ 下一步 (前往付款)
                  </button>
                  <button type="button" id="back-to-step2-from-invoice" class="mt-4 text-light hover:text-dark underline text-sm block mx-auto">
                    🔙 返回修改参与者信息
                  </button>
                </div>
              </form>
            </div>

            <!-- Checkout Section (Step 4, hidden initially) -->
            <div id="checkout-section" class="hidden py-8">
              <h3 class="text-2xl font-bold text-dark text-center mb-6">✅ Step 4: 确认并付款</h3>
              
              <div class="bg-theme-light border border-border-light p-8 rounded-xl max-w-md mx-auto mb-8 shadow-sm">
                <h4 class="font-bold text-dark border-b border-border-light pb-2 mb-4">订单摘要</h4>
                <div class="space-y-3 text-base">
                  <div class="flex justify-between">
                    <span class="text-light">报名人数:</span>
                    <span class="font-bold text-dark" id="summary-pax">1 人</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-light">小计:</span>
                    <span class="font-bold text-dark" id="summary-subtotal">RM 128.00</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-light">SST (8%):</span>
                    <span class="font-bold text-dark" id="summary-sst">RM 10.24</span>
                  </div>
                  <div class="flex justify-between pt-3 border-t border-border-light">
                    <span class="font-bold text-dark text-lg">总计:</span>
                    <span class="font-bold text-primary text-2xl" id="summary-total">RM 138.24</span>
                  </div>
                </div>
              </div>

              <div class="text-center">
                <button id="pay-now-btn" type="button" class="w-full max-w-md mx-auto bg-[#ffb700] hover:bg-[#e5a400] text-dark font-bold text-lg px-8 py-4 rounded-xl transition duration-300 shadow-md flex items-center justify-center gap-2">
                  💳 立即付款 (Pay Now)
                </button>
                <div id="pay-now-loading" class="hidden text-light text-sm mt-3 flex items-center justify-center gap-2">
                  <div class="w-4 h-4 border-2 border-primary border-t-transparent rounded-full animate-spin"></div>
                  正在处理订单并打开支付页面...
                </div>
                <button type="button" id="back-to-step3-btn" class="mt-4 text-light hover:text-dark underline text-sm">
                  🔙 返回修改发票信息
                </button>
              </div>
            </div>

            <!-- Thank You Message (hidden by default) -->
            <div id="thank-you-msg" class="hidden text-center py-12 space-y-6">
              <div class="text-6xl mb-4">🎉</div>
              <h3 class="text-2xl font-bold text-dark">谢谢您的报名！</h3>
              <p class="text-light text-lg">付款成功！我们会尽快与您联系，确认席位详情。</p>
              <button id="buy-again-btn" type="button" class="inline-block bg-primary hover:bg-theme-dark text-white font-bold text-lg px-8 py-4 rounded-xl transition duration-300 shadow-md">
                🔄 再次报名
              </button>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</Base>

<script>
  // --- Dynamic Pax Availability ---
  document.addEventListener('DOMContentLoaded', async () => {
    const container = document.getElementById('pax-countdown-container');
    if (!container) return; // Exit early if the section is disabled via SHOW_PAX_COUNTDOWN

    try {
      const response = await fetch('/api/get_pax/');
      const data = await response.json();
      if (container && data.remainingPax !== undefined) {
        container.classList.remove('hidden');
        if (data.remainingPax > 0 && data.remainingPax <= 20) {
          container.innerHTML = `🔥 紧急！仅剩 <strong class="text-2xl text-red-600">${data.remainingPax}</strong> 个席位！`;
        } else if (data.remainingPax <= 0) {
          container.innerHTML = `🚫 名额已满！`;
          
          // Disable the Step 1 form if sold out
          const ogsmForm = document.getElementById('ogsm-form');
          if (ogsmForm) {
            // Disable all inputs and textareas
            const elements = ogsmForm.querySelectorAll('input, textarea');
            elements.forEach(el => (el as HTMLInputElement).disabled = true);
            
            // Disable submit button and change text
            const nextBtn = document.getElementById('next-step-btn') as HTMLButtonElement;
            if (nextBtn) {
              nextBtn.disabled = true;
              nextBtn.innerHTML = '🚫 已满额，报名通道关闭';
              nextBtn.classList.remove('bg-primary', 'hover:bg-theme-dark');
              nextBtn.classList.add('bg-gray-400', 'cursor-not-allowed');
            }
          }
        } else {
          container.innerHTML = `✅ 席位充足`;
        }
      }
    } catch (error) {
      console.error('Failed to load pax countdown:', error);
    }
  });

  // --- Capture UTM parameters from URL on page load ---
  const _urlParams = new URLSearchParams(window.location.search);
  const utmMedium = _urlParams.get('utm_medium') || '';
  const utmContent = _urlParams.get('utm_content') || '';

  const paxInput = document.getElementById('pax') as HTMLInputElement;
  const minusBtn = document.getElementById('pax-minus')!;
  const plusBtn = document.getElementById('pax-plus')!;
  const rowOriginal = document.getElementById('row-original')!;
  const paxCount = document.getElementById('pax-count')!;
  const priceOriginal = document.getElementById('price-original')!;
  const priceSubtotal = document.getElementById('price-subtotal')!;
  const priceSst = document.getElementById('price-sst')!;
  const priceTotal = document.getElementById('price-total')!;
  const savingsHint = document.getElementById('savings-hint')!;
  const savingsText = document.getElementById('savings-text')!;
  const attendeesContainer = document.getElementById('attendees-container')!;

  const PRICE_PER_PAX = 128;
  const SST_RATE = 0.08;

  function calcSubtotal(pax: number): number {
    if (pax === 1) return 128;
    if (pax === 2) return 199;
    // 3+ pax: base 199 + 99 for each person beyond 2
    return 199 + (pax - 2) * 99;
  }

  function updatePricing() {
    const pax = parseInt(paxInput.value) || 1;
    const fullPrice = pax * PRICE_PER_PAX;
    const subtotal = calcSubtotal(pax);
    const sst = subtotal * SST_RATE;
    const total = subtotal + sst;

    // Show original price row only when there's a discount (2+ pax)
    if (pax >= 2) {
      paxCount.textContent = String(pax);
      priceOriginal.textContent = `RM ${fullPrice.toFixed(2)}`;
      rowOriginal.classList.remove('hidden');
      const saved = fullPrice - subtotal;
      savingsHint.classList.remove('hidden');
      savingsText.textContent = `团报优惠！省下 RM ${saved.toFixed(2)}`;
    } else {
      rowOriginal.classList.add('hidden');
      savingsHint.classList.add('hidden');
    }

    priceSubtotal.textContent = `RM ${subtotal.toFixed(2)}`;
    priceSst.textContent = `RM ${sst.toFixed(2)}`;
    priceTotal.textContent = `RM ${total.toFixed(2)}`;
    
    updateAttendeeFields(pax);
  }

  function updateAttendeeFields(pax: number) {
    if (!attendeesContainer) return;
    const currentCount = attendeesContainer.children.length;
    
    if (pax > currentCount) {
        // Add new blocks
        for (let i = currentCount + 1; i <= pax; i++) {
            const div = document.createElement('div');
            div.className = 'bg-theme-light border border-border-light p-6 rounded-xl space-y-4 attendee-block';
            div.id = `attendee-block-${i}`;
            div.innerHTML = `
              <h4 class="font-bold text-dark border-b border-border-light pb-2 mb-4">Participant ${i} (参与者 ${i})</h4>
              <div>
                <label class="block text-sm font-semibold text-dark mb-2">FULL NAME as per IC *</label>
                <input type="text" name="attendee_name_${i}" class="w-full px-4 py-3 rounded-lg border border-border-light focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" required placeholder="如：Ali Bin Ahmad">
              </div>
              <div>
                <label class="block text-sm font-semibold text-dark mb-2">IC No. *</label>
                <input type="text" name="attendee_ic_${i}" class="w-full px-4 py-3 rounded-lg border border-border-light focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" required placeholder="如：900101-14-1234">
              </div>
              <div>
                <label class="block text-sm font-semibold text-dark mb-2">Phone No. *</label>
                <input type="tel" name="attendee_phone_${i}" class="w-full px-4 py-3 rounded-lg border border-border-light focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" required placeholder="如：0123456789">
              </div>
            `;
            attendeesContainer.appendChild(div);
        }
    } else if (pax < currentCount) {
        // Remove extra blocks
        for (let i = currentCount; i > pax; i--) {
            const block = document.getElementById(`attendee-block-${i}`);
            if (block) {
                block.remove();
            }
        }
    }
  }

  minusBtn.addEventListener('click', () => {
    const current = parseInt(paxInput.value) || 1;
    if (current > 1) {
      paxInput.value = String(current - 1);
      updatePricing();
    }
  });

  plusBtn.addEventListener('click', () => {
    const current = parseInt(paxInput.value) || 1;
    if (current < 20) {
      paxInput.value = String(current + 1);
      updatePricing();
    }
  });

  // Initialize
  updatePricing();

  // --- Formatting Event Listener ---
  document.addEventListener('input', (e: any) => {
    const target = e.target as HTMLInputElement;
    if (!target || !target.name) return;
    
    // Phone Formatter
    if (target.name === 'phone' || target.name.startsWith('attendee_phone_') || target.name === 'inv_phone') {
      let val = target.value.replace(/\D/g, '');
      if (val.length > 11) val = val.slice(0, 11);
      
      if (val.startsWith('011')) {
        if (val.length > 7) {
          target.value = val.slice(0, 3) + ' ' + val.slice(3, 7) + ' ' + val.slice(7);
        } else if (val.length > 3) {
          target.value = val.slice(0, 3) + ' ' + val.slice(3);
        } else {
          target.value = val;
        }
      } else {
        if (val.length > 6) {
          target.value = val.slice(0, 3) + '-' + val.slice(3, 6) + ' ' + val.slice(6);
        } else if (val.length > 3) {
          target.value = val.slice(0, 3) + '-' + val.slice(3);
        } else {
          target.value = val;
        }
      }
    }
    
    // IC Formatter
    if (target.name.startsWith('attendee_ic_')) {
      let val = target.value.replace(/\D/g, '');
      if (val.length > 12) val = val.slice(0, 12);
      
      if (val.length > 8) {
        target.value = val.slice(0, 6) + '-' + val.slice(6, 8) + '-' + val.slice(8);
      } else if (val.length > 6) {
        target.value = val.slice(0, 6) + '-' + val.slice(6);
      } else {
        target.value = val;
      }
    }
  });

  // --- Element references ---
  const form = document.getElementById('ogsm-form') as HTMLFormElement;
  const invoiceSection = document.getElementById('invoice-section')!;
  const invoiceForm = document.getElementById('invoice-form') as HTMLFormElement;
  const participantsSection = document.getElementById('participants-section')!;
  const participantsForm = document.getElementById('participants-form') as HTMLFormElement;
  const checkoutSection = document.getElementById('checkout-section')!;
  const payNowBtn = document.getElementById('pay-now-btn') as HTMLButtonElement;
  const payNowLoading = document.getElementById('pay-now-loading')!;
  
  const backToStep1FromParticipants = document.getElementById('back-to-step1-from-participants')!;
  const backToStep2FromInvoice = document.getElementById('back-to-step2-from-invoice')!;
  const backToStep3Btn = document.getElementById('back-to-step3-btn')!;

  const summaryPax = document.getElementById('summary-pax')!;
  const summarySubtotal = document.getElementById('summary-subtotal')!;
  const summarySst = document.getElementById('summary-sst')!;
  const summaryTotal = document.getElementById('summary-total')!;

  // --- Step 1 → Step 2: Save lead, then show Participants form ---
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const name = (document.getElementById('name') as HTMLInputElement).value.trim();
    const company = (document.getElementById('company') as HTMLInputElement).value.trim();
    const position = (document.getElementById('position') as HTMLInputElement).value.trim();
    const phone = ((document.getElementById('phone') as HTMLInputElement).value.trim()).replace(/\D/g, '');
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const diagnosis = (document.getElementById('diagnosis') as HTMLTextAreaElement).value.trim();

    const nextBtn = document.getElementById('next-step-btn') as HTMLButtonElement;
    const originalNextText = nextBtn.innerHTML;

    nextBtn.disabled = true;
    nextBtn.innerHTML = '⏳ 正在保存信息...';

    try {
      // Save the lead into Google Sheet immediately
      const res = await fetch('/api/save_lead/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          action: 'save_lead',
          name, company, position, phone, email, diagnosis,
          utm_medium: utmMedium,
          utm_content: utmContent,
        }),
      });

      if (!res.ok) {
         console.warn("Could not save lead to Google Sheet, but letting user continue.");
      }

      // Initialize Attendee fields if first time viewing Step 2
      updatePricing();

      // Auto-fill Attendee 1 based on Step 1 lead info
      const t1Name = document.querySelector('input[name="attendee_name_1"]') as HTMLInputElement;
      const t1Phone = document.querySelector('input[name="attendee_phone_1"]') as HTMLInputElement;
      if (t1Name && !t1Name.value) t1Name.value = name;
      if (t1Phone && !t1Phone.value) t1Phone.value = phone;

      // Switch UI: Step 1 → Step 2 (Participants)
      form.classList.add('hidden');
      participantsSection.classList.remove('hidden');
    } catch (err) {
      console.error(err);
      alert('保存失败，请检查网络后重试。');
    } finally {
      nextBtn.disabled = false;
      nextBtn.innerHTML = originalNextText;
    }
  });

  // --- Step 2 back → Step 1 ---
  backToStep1FromParticipants.addEventListener('click', () => {
    participantsSection.classList.add('hidden');
    form.classList.remove('hidden');
  });

  // --- Step 2 → Step 3: Save participants, then show invoice ---
  participantsForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!participantsForm.checkValidity()) {
      participantsForm.reportValidity();
      return;
    }

    // Double check Step 1 values are still valid
    if (!form.checkValidity()) {
      alert("请返回第一步填写完整信息");
      return;
    }

    const pax = parseInt(paxInput.value) || 1;
    const attendeesData = [];
    for (let i = 1; i <= pax; i++) {
      attendeesData.push({
        name: (document.querySelector(`input[name="attendee_name_${i}"]`) as HTMLInputElement)?.value || '',
        ic: ((document.querySelector(`input[name="attendee_ic_${i}"]`) as HTMLInputElement)?.value || '').replace(/\D/g, ''),
        phone: ((document.querySelector(`input[name="attendee_phone_${i}"]`) as HTMLInputElement)?.value || '').replace(/\D/g, ''),
      });
    }

    const leadEmail = (document.getElementById('email') as HTMLInputElement).value.trim();
    const btn = document.getElementById('participants-next-btn') as HTMLButtonElement;
    const originalText = btn.innerHTML;
    
    btn.disabled = true;
    btn.innerHTML = '⏳ 正在保存信息...';

    try {
      const res = await fetch('/api/save_lead/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          action: 'save_attendees',
          bill_email: leadEmail,
          pax: pax,
          attendees: attendeesData,
        }),
      });

      if (!res.ok) {
        console.warn('Could not save attendees to Google Sheet, but letting user continue.');
      }

      // Auto-fill invoice fields from Step 1 data
      const company = (document.getElementById('company') as HTMLInputElement).value.trim();
      const phone = (document.getElementById('phone') as HTMLInputElement).value.trim();
      const email = (document.getElementById('email') as HTMLInputElement).value.trim();
      
      const invCompanyEl = document.getElementById('inv_company') as HTMLInputElement;
      const invPhoneEl = document.getElementById('inv_phone') as HTMLInputElement;
      const invEmailEl = document.getElementById('inv_email') as HTMLInputElement;
      if (!invCompanyEl.value) invCompanyEl.value = company;
      if (!invPhoneEl.value) invPhoneEl.value = phone;
      if (!invEmailEl.value) invEmailEl.value = email;

      // Switch UI: Step 2 → Step 3 (Invoice)
      participantsSection.classList.add('hidden');
      invoiceSection.classList.remove('hidden');
    } catch (err) {
      console.error(err);
      alert('保存参与者信息失败，请检查网络后重试。');
    } finally {
      btn.disabled = false;
      btn.innerHTML = originalText;
    }
  });

  // --- Step 3 back → Step 2 ---
  backToStep2FromInvoice.addEventListener('click', () => {
    invoiceSection.classList.add('hidden');
    participantsSection.classList.remove('hidden');
  });

  // --- Step 3 → Step 4: Validate invoice, save to sheet, then show Summary/Payment ---
  invoiceForm.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!invoiceForm.checkValidity()) {
      invoiceForm.reportValidity();
      return;
    }

    // Validate Previous forms again just in case
    if (!form.checkValidity() || !participantsForm.checkValidity()) {
      alert("请确保前面的信息已填写完整");
      return;
    }

    const invCompany = (document.getElementById('inv_company') as HTMLInputElement).value.trim();
    const invAddress = (document.getElementById('inv_address') as HTMLTextAreaElement).value.trim();
    const invPhone = ((document.getElementById('inv_phone') as HTMLInputElement).value.trim()).replace(/\D/g, '');
    const invEmail = (document.getElementById('inv_email') as HTMLInputElement).value.trim();
    const leadEmail = (document.getElementById('email') as HTMLInputElement).value.trim();

    const invoiceNextBtn = document.getElementById('invoice-next-btn') as HTMLButtonElement;
    const originalInvoiceText = invoiceNextBtn.innerHTML;

    invoiceNextBtn.disabled = true;
    invoiceNextBtn.innerHTML = '⏳ 正在保存发票信息...';

    try {
      const res = await fetch('/api/save_lead/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          action: 'save_invoice',
          bill_email: leadEmail,
          inv_company: invCompany,
          inv_address: invAddress,
          inv_phone: invPhone,
          inv_email: invEmail,
        }),
      });

      if (!res.ok) {
        console.warn('Could not save invoice to Google Sheet, but letting user continue.');
      }

      // Update Step 4 Summary UI
      const pax = parseInt(paxInput.value) || 1;
      summaryPax.textContent = `${pax} 人`;
      summarySubtotal.textContent = priceSubtotal.textContent;
      summarySst.textContent = priceSst.textContent;
      summaryTotal.textContent = priceTotal.textContent;

      // Switch UI: Step 3 → Step 4 (Summary)
      invoiceSection.classList.add('hidden');
      checkoutSection.classList.remove('hidden');
    } catch (err) {
      console.error(err);
      alert('保存发票信息失败，请检查网络后重试。');
    } finally {
      invoiceNextBtn.disabled = false;
      invoiceNextBtn.innerHTML = originalInvoiceText;
    }
  });

  // --- Step 4 back → Step 3 ---
  backToStep3Btn.addEventListener('click', () => {
    checkoutSection.classList.add('hidden');
    invoiceSection.classList.remove('hidden');
  });

  // --- Payment submission flow (Step 4) ---
  payNowBtn.addEventListener('click', async () => {
    
    // Double check form values are still valid
    if (!form.checkValidity()) {
      alert("请返回第一步填写完整信息");
      return;
    }

    const name = (document.getElementById('name') as HTMLInputElement).value.trim();
    const phone = ((document.getElementById('phone') as HTMLInputElement).value.trim()).replace(/\D/g, '');
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const pax = parseInt(paxInput.value) || 1;
    const subtotal = calcSubtotal(pax);
    const sst = subtotal * SST_RATE;
    const total = subtotal + sst;
    const totalRounded = parseFloat(total.toFixed(2));

    const company = (document.getElementById('company') as HTMLInputElement).value.trim();
    const position = (document.getElementById('position') as HTMLInputElement).value.trim();
    const diagnosis = (document.getElementById('diagnosis') as HTMLTextAreaElement).value.trim();

    const billDesc = `${pax} pax《OGSM + KFI（财务指标）实战工作坊》`;

    // 1. Immediately open window in sync click handler to bypass block
    const w = 500, h = 650;
    const left = (screen.width - w) / 2;
    const top = (screen.height - h) / 2;
    let popup = window.open('about:blank', 'fiuu_payment', `width=${w},height=${h},left=${left},top=${top},scrollbars=yes,resizable=yes`);
    
    if (popup) {
      popup.document.write('<html><body style="display:flex;align-items:center;justify-content:center;height:100vh;font-family:sans-serif;color:#555;flex-direction:column;"><div style="border: 3px solid #f3f3f3; border-top: 3px solid #ffb700; border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; margin-bottom: 20px;"></div><p>⏳ 请稍等，正在创建订单与支付页面...</p><style>@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }</style></body></html>');
    }

    // Update UI Loading State
    payNowBtn.classList.add('hidden');
    payNowLoading.classList.remove('hidden');
    backToStep3Btn.classList.add('hidden');

    try {
      // 2. Await API creation of Order and Webhook event
      const res = await fetch('/api/checkout/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          amount: totalRounded,
          bill_name: name,
          bill_email: email,
          bill_mobile: phone,
          bill_desc: billDesc,
          pax: pax,
          company: company,
          position: position,
          diagnosis: diagnosis,
        }),
      });

      if (!res.ok) {
        const errData = await res.json();
        throw new Error(errData.error || 'Checkout failed');
      }

      const paymentData = await res.json();
      
      const extraParams = {
        company, position, diagnosis, pax
      };

      // 3. Post to FIUU in the launched window
      const paymentForm = document.createElement('form');
      paymentForm.method = 'POST';
      paymentForm.action = paymentData.payment_url;
      paymentForm.target = 'fiuu_payment';
      paymentForm.style.display = 'none';

      const fields: Record<string, string> = {
        merchant_id: paymentData.merchant_id,
        amount: paymentData.amount,
        orderid: paymentData.orderid,
        bill_name: paymentData.bill_name,
        bill_email: paymentData.bill_email,
        bill_mobile: paymentData.bill_mobile,
        bill_desc: paymentData.bill_desc,
        vcode: paymentData.vcode,
        currency: paymentData.currency,
        channel: paymentData.channel,
        returnurl: paymentData.returnurl,
        callbackurl: paymentData.callbackurl,
        extraP: JSON.stringify(extraParams),
      };

      for (const [key, val] of Object.entries(fields)) {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = key;
        input.value = val;
        paymentForm.appendChild(input);
      }

      document.body.appendChild(paymentForm);
      paymentForm.submit();
      paymentForm.remove();

      // Start polling for popup closure
      const pollTimer = setInterval(() => {
        if (!popup || popup.closed) {
          clearInterval(pollTimer);
          showThankYou();
        }
      }, 500);

    } catch (err: any) {
      if (popup && !popup.closed) popup.close();
      alert('\u63d0\u4ea4\u5931\u8d25\uff1a' + (err.message || '\u8bf7\u7a0d\u540e\u518d\u8bd5'));
    } finally {
      payNowBtn.classList.remove('hidden');
      payNowLoading.classList.add('hidden');
      backToStep3Btn.classList.remove('hidden');
    }
  });

  // --- Thank you / buy again flow ---
  const thankYouMsg = document.getElementById('thank-you-msg')!;
  const buyAgainBtn = document.getElementById('buy-again-btn')!;

  function showThankYou() {
    form.classList.add('hidden');
    invoiceSection.classList.add('hidden');
    participantsSection.classList.add('hidden');
    checkoutSection.classList.add('hidden');
    thankYouMsg.classList.remove('hidden');
  }

  buyAgainBtn.addEventListener('click', () => {
    form.reset();
    invoiceForm.reset();
    if (participantsForm) participantsForm.reset();
    if (attendeesContainer) attendeesContainer.innerHTML = '';
    paxInput.value = '1';
    updatePricing();
    thankYouMsg.classList.add('hidden');
    checkoutSection.classList.add('hidden');
    participantsSection.classList.add('hidden');
    invoiceSection.classList.add('hidden');
    form.classList.remove('hidden');
  });
</script>
